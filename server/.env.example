PORT=3001
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret

# 开发演示可自动创建管理员；生产环境建议关闭并手动创建/改密
CREATE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@musehub.com
DEFAULT_ADMIN_PASSWORD=admin123

# 访问 TMDB、Open Library 时可选（国内网络无法直连时，填本机 HTTP 代理，如 Clash）
# HTTPS_PROXY=http://127.0.0.1:7890
# 出站请求超时毫秒（默认 12000）
# OUTBOUND_TIMEOUT_MS=12000

TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
GOOGLE_BOOKS_BASE_URL=https://www.googleapis.com/books/v1
NETEASE_API_BASE_URL=http://localhost:3002

# AI Assistant (兼容 OpenAI 格式的 API，推荐 DeepSeek)
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=2048
AI_DAILY_LIMIT=100
